# Copy this file to `.env` and fill in the endpoint values.
#
# Paths
# Leave REPO_ROOT empty if this workspace stays in the repository root.
REPO_ROOT=
# Default if empty: ./data/olmOCR-bench/bench_data
BENCH_DATA_DIR=
# Default if empty: $BENCH_DATA_DIR/pdfs
BENCH_PDF_DIR=
# Default if empty: ./results
RESULTS_DIR=

# Candidate names
QWEN_STRUCTURED_CANDIDATE=qwen_structured
QWEN_STRUCTURED_POST_CANDIDATE=qwen_structured_post
SVR_OCR_CANDIDATE=svr_ocr_full
OLMOCR2_CANDIDATE=olmocr2

# Models
QWEN_MODEL=qwen3-vl-plus
OLMOCR_MODEL=allenai/olmOCR-2-7B-1025-FP8

# OpenAI-compatible endpoints
QWEN_SERVER=
QWEN_API_KEY=

OLMOCR_SERVER=
OLMOCR_API_KEY=

export NVIDIA_SERVER="https://integrate.api.nvidia.com/v1"
export NVIDIA_MODEL="nvidia/nemotron-3-nano-omni-30b-a3b-reasoning"
export NVIDIA_API_KEY=

# NVIDIA PDF eval controls
export NVIDIA_CANDIDATE=nemotron_omni_nvidia_ocr
export NVIDIA_PARALLEL=1
export NVIDIA_PROMPT_TEMPLATE=nvidia_ocr
export NVIDIA_BOOTSTRAP_SAMPLES=200
export NVIDIA_MAX_REPORTS=20

# NVIDIA audio eval controls
export AUDIO_SAMPLES_PER_DATASET=100
export AUDIO_MAX_DURATION=3
export AUDIO_MAX_TOKENS=128
export AUDIO_REQUEST_SLEEP=3
export AUDIO_RETRIES=6
export AUDIO_RETRY_SLEEP=5
export AUDIO_PROMPT_STYLE=strict

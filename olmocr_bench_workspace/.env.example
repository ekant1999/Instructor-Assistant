# Copy this file to `.env` and fill in the endpoint values.
#
# Paths
# Leave REPO_ROOT empty if this workspace stays in the repository root.
REPO_ROOT=
# Default if empty: ./data/olmOCR-bench/bench_data
BENCH_DATA_DIR=
# Default if empty: $BENCH_DATA_DIR/pdfs
BENCH_PDF_DIR=
# Default if empty: ./results
RESULTS_DIR=

# Candidate names
QWEN_STRUCTURED_CANDIDATE=qwen_structured
QWEN_STRUCTURED_POST_CANDIDATE=qwen_structured_post
SVR_OCR_CANDIDATE=svr_ocr_full
OLMOCR2_CANDIDATE=olmocr2

# Models
QWEN_MODEL=qwen3-vl-plus
OLMOCR_MODEL=allenai/olmOCR-2-7B-1025-FP8

# OpenAI-compatible endpoints
QWEN_SERVER=
QWEN_API_KEY=

OLMOCR_SERVER=
OLMOCR_API_KEY=


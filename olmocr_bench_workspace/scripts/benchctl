#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PYTHON_BIN="${ROOT_DIR}/.venv/bin/python"

if [[ ! -x "${PYTHON_BIN}" ]]; then
  echo "Workspace venv not found. Run ${ROOT_DIR}/scripts/setup_workspace.sh first." >&2
  exit 1
fi

exec "${PYTHON_BIN}" "${ROOT_DIR}/tools/experiment.py" "$@"

